# Foundry Customer Service Agent — environment template.
#
# Copy to `.env` and populate, or `export` these in your shell before running
# `setup_agent.py`, `create_a2a_connection.py`, or `test_agent.py`.
#
# Step 11 of plan.md.

# Foundry project endpoint (from Bicep output `foundryProjectEndpoint`).
# Format: https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>
FOUNDRY_PROJECT_ENDPOINT=https://<foundry-account>.services.ai.azure.com/api/projects/<project-name>

# Orchestrator model deployment name (from Bicep output `orchestratorDeploymentName`).
# Same logical name in either `useGpt55=true` or `useGpt55=false` configurations.
FOUNDRY_ORCHESTRATOR_DEPLOYMENT=gpt-55-orchestrator

# Name of the Foundry A2A connection that points at the AKS Ops Agent.
# Created via the Foundry portal (see `create_a2a_connection.py`).
A2A_CONNECTION_NAME=ops-agent-a2a

# Name of the Foundry prompt agent created by `setup_agent.py`.
FOUNDRY_AGENT_NAME=zava-customer-service

# Public HTTPS endpoint for the Ops Agent on AKS (from Bicep output `opsAgentUrl`).
# Trailing slash is required by the A2A connection form.
OPS_AGENT_ENDPOINT=https://ops-agent.zava.example.com/

# Pre-shared API key the Foundry A2A connection sends as the `x-api-key`
# header. Generated by the deploy script in Step 15 and stored in the
# `ops-agent-secrets` K8s Secret. Retrieve with:
#   kubectl get secret ops-agent-secrets -o jsonpath='{.data.A2A_API_KEY}' | base64 -d
OPS_AGENT_API_KEY=<paste from kubectl get secret>
